{
  "name": "ocuclaw",
  "version": "1.3.4",
  "requiresClientVersion": "1.3.4",
  "description": "OcuClaw for Even Realities G2 smart glasses.",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "README.md",
    "dist/",
    "openclaw.plugin.json",
    "skills/"
  ],
  "keywords": [
    "even",
    "evenrealities",
    "even-g2",
    "glasses",
    "openclaw",
    "plugin",
    "ocuclaw"
  ],
  "engines": {
    "node": ">=20"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "clawhub:ocuclaw",
      "npmSpec": "ocuclaw",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.9"
    },
    "compat": {
      "pluginApi": ">=2026.6.9"
    },
    "build": {
      "openclawVersion": "2026.6.9",
      "bundledDist": true
    }
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "marked": "^17.0.2",
    "undici": "^6.26.0",
    "ws": "^8.19.0"
  }
}
